<Window x:Class="KingIOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="King iOS - Windows Desktop App"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#0D0D1A" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Margin="5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="King iOS" FontSize="12" FontWeight="SemiBold" Foreground="#E94560" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Grid.Column="1" Text="v1.0.0" FontSize="11" Foreground="#555" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <Border Grid.Column="2" Background="#0F3460" CornerRadius="3" VerticalAlignment="Center">
                        <Button Content="🗔 King PC" 
                                x:Name="KingPCButton"
                                Click="KingPCButton_Click"
                                Background="Transparent" Foreground="White" BorderThickness="0" 
                                FontSize="11" Padding="10,3" Cursor="Hand"/>
</Border>
                <Button Grid.Column="3" Content="—" 
                        x:Name="MinimizeButton"
                        Click="MinimizeButton_Click"
                        Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" 
                        FontSize="16" Width="30" Height="25" Cursor="Hand"/>
                <Button Grid.Column="4" Content="✕" 
                        x:Name="CloseButton"
                        Click="CloseButton_Click"
                        Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" 
                        FontSize="14" Width="30" Height="25" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Main Content Frame -->
        <Frame x:Name="MainFrame" 
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>