<Page x:Class="KingIOS.Views.MainMenuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="King iOS"
      WindowTitle="King iOS"
      Background="#1A1A2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,30">
            <TextBlock Text="King iOS" 
                       FontSize="48" 
                       FontWeight="Bold" 
                       Foreground="#E94560"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Transform your iPhone with the power of Android"
                       FontSize="16" 
                       Foreground="#A0A0B0"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,40">
            <Button Content="Emily on iPhone" 
                    Command="{Binding NavigateToEmilyCommand}"
                    Style="{StaticResource MenuButton}"
                    Margin="0,0,0,20">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="Emily on iPhone" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Download the IPA to test King iOS on your iPhone" FontSize="12" Foreground="#A0A0B0" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Install King iOS" 
                    Command="{Binding NavigateToInstallCommand}"
                    Style="{StaticResource MenuButton}">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="Install King iOS" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Permanently install King iOS on your device" FontSize="12" Foreground="#A0A0B0" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <TextBlock Grid.Row="3" 
                   Text="v1.0.0 - King iOS Project"
                   FontSize="12"
                   Foreground="#555"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,20"/>
    </Grid>
</Page>