<Page x:Class="KingIOS.Views.InstallView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E"
      Title="Install King iOS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#16213E" BorderBrush="#2A2A4A" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Back" 
                        Command="{Binding GoBackCommand}"
                        Background="Transparent" 
                        Foreground="#A0A0B0" 
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"/>

                <TextBlock Grid.Column="1" 
                           Text="Install King iOS" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <Button Grid.Column="2" 
                        Content="Restore iPhone" 
                        Command="{Binding RestoreiPhoneCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="15,8"
                        FontSize="13"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3" 
                        Content="Get iPhone Data" 
                        Command="{Binding GetiPhoneDataCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="15,8"
                        FontSize="13"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="4" 
                        Content="Install King iOS" 
                        Command="{Binding InstallKingiOSCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="15,8"
                        FontSize="13"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar - Device List -->
            <Border Grid.Column="0" Background="#16213E" BorderBrush="#2A2A4A" BorderThickness="0,0,1,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Connected Devices" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="White"/>
                        <Button Content="⟳ Refresh" 
                                Command="{Binding RefreshDevicesCommand}"
                                Background="Transparent"
                                Foreground="#E94560"
                                BorderThickness="0"
                                FontSize="12"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                Padding="0"/>
                    </StackPanel>

                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding ConnectedDevices}"
                              SelectedItem="{Binding SelectedDevice}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2E" 
                                        CornerRadius="8" 
                                        Padding="12,10" 
                                        Margin="0,0,0,5"
                                        BorderBrush="#2A2A4A"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="White"/>
                                        <TextBlock Text="{Binding DisplayName}" 
                                                   FontSize="11" 
                                                   Foreground="#A0A0B0" 
                                                   Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding Status}" 
                                                   FontSize="11" 
                                                   Foreground="#4CAF50"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right Panel - Instructions -->
            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Instructions" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Follow the steps below to install King iOS on your device."
                               FontSize="13" 
                               Foreground="#A0A0B0" 
                               Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <Border Background="#16213E" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Step 1: Back Up Your Data" 
                                           FontSize="16" 
                                           FontWeight="SemiBold" 
                                           Foreground="#E94560"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" FontSize="13" Foreground="#A0A0B0">
                                    It is highly recommended to back up your iPhone data before installing King iOS. 
                                    Click "Get iPhone Data" to save your data to a folder on your PC. 
                                    This ensures you can restore your phone to its original state at any time.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#16213E" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Step 2: Select Your Device" 
                                           FontSize="16" 
                                           FontWeight="SemiBold" 
                                           Foreground="#E94560"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" FontSize="13" Foreground="#A0A0B0">
                                    Connect your iPhone via USB. It will appear in the device list on the left. 
                                    Click on it to select it before proceeding with the installation.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#16213E" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Step 3: Install King iOS" 
                                           FontSize="16" 
                                           FontWeight="SemiBold" 
                                           Foreground="#E94560"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" FontSize="13" Foreground="#A0A0B0">
                                    Click "Install King iOS" to begin the installation process. 
                                    Your device will be put into DFU mode automatically. 
                                    Follow the on-screen prompts to complete the installation.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#16213E" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Restoring Your iPhone" 
                                           FontSize="16" 
                                           FontWeight="SemiBold" 
                                           Foreground="#0F3460"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" FontSize="13" Foreground="#A0A0B0">
                                    If you ever want to go back to your original iOS setup:
                                    1. Click "Restore iPhone"
                                    2. Point to the folder where you saved your backup
                                    3. Your iPhone will be restored to its previous state
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Status Bar -->
                <Border Grid.Row="2" Background="#16213E" CornerRadius="8" Padding="15,10" Margin="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding StatusMessage}" 
                                   FontSize="12" 
                                   Foreground="#A0A0B0"
                                   VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" 
                                     Value="{Binding ProgressValue}" 
                                     Minimum="0" 
                                     Maximum="100"
                                     Height="6"
                                     Foreground="#E94560"
                                     Background="#2A2A4A"
                                     BorderThickness="0"
                                     Margin="10,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>