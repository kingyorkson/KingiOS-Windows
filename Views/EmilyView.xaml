<Page x:Class="KingIOS.Views.EmilyView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E"
      Title="Emily on iPhone">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16213E" BorderBrush="#2A2A4A" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back" 
                        Command="{Binding GoBackCommand}"
                        Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                <TextBlock Grid.Column="1" Text="Emily on iPhone" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500" Margin="30">
            <TextBlock Text="Emily on iPhone" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#A0A0B0" HorizontalAlignment="Center" Margin="0,10,0,30" TextWrapping="Wrap"/>

            <Border Background="#16213E" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="GitHub IPA Download" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#A0A0B0" Margin="0,0,0,15">
                        The King iOS IPA is hosted on GitHub. You can download it to test the custom Android 
                        experience on your iPhone using sideloading tools like AltStore or SideLoadly.
                    </TextBlock>
                    <TextBox Text="{Binding GitHubUrl, Mode=OneWay}" 
                             IsReadOnly="True"
                             Background="#1A1A2E"
                             Foreground="#E94560"
                             BorderBrush="#2A2A4A"
                             Padding="10"
                             Margin="0,0,0,10"/>
                    <Button Content="Open GitHub Page" 
                            Command="{Binding OpenGitHubCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Height="40"
                            Margin="0,0,0,10"/>
                    <Button Content="Download IPA" 
                            Command="{Binding DownloadIpaCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="45"/>
                    <ProgressBar Value="{Binding ProgressValue}" 
                                 Minimum="0" Maximum="100"
                                 Height="6"
                                 Foreground="#E94560"
                                 Background="#2A2A4A"
                                 BorderThickness="0"
                                 Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#16213E" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="How to use the IPA" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#A0A0B0">
                        1. Download the IPA file from GitHub
                        2. Use AltStore or SideLoadly to sideload to your iPhone
                        3. Open the app on your iPhone to experience the custom Android emulator
                        4. The emulator includes a custom home button for navigation
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>