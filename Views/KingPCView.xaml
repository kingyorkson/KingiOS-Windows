<Page x:Class="KingIOS.Views.KingPCView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E"
      Title="King PC">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16213E" BorderBrush="#2A2A4A" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back" 
                        Command="{Binding GoBackCommand}"
                        Background="Transparent" Foreground="#A0A0B0" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                <TextBlock Grid.Column="1" Text="King PC" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <Button Grid.Column="2" Content="❓ Help" 
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,8"
                        FontSize="12"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="30">
            <StackPanel MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">

                <TextBlock Text="King PC" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#A0A0B0" HorizontalAlignment="Center" Margin="0,5,0,25" TextWrapping="Wrap"/>

                <!-- Scan Section -->
                <Border Background="#16213E" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Available Devices" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <Button Content="🔍 Scan for Devices" 
                                Command="{Binding ScanCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="40"
                                Margin="0,10,0,0"/>
                        <ItemsControl ItemsSource="{Binding AvailableDevices}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A2E" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" BorderBrush="#2A2A4A" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="{Binding IpAddress}" FontSize="11" Foreground="#A0A0B0"/>
                                            </StackPanel>
                                            <RadioButton Grid.Column="1" 
                                                         GroupName="DeviceSelection"
                                                         IsChecked="{Binding IsSelected}"
                                                         VerticalAlignment="Center"
                                                         Foreground="#E94560"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Connect Selected Device" 
                                Command="{Binding ConnectDeviceCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="40"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Connected Devices Section -->
                <Border Background="#16213E" CornerRadius="12" Padding="20" Margin="0,0,0,15"
                        Visibility="{Binding ShowDeviceList, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Connected Devices" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding ConnectedDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A2E" CornerRadius="8" Padding="12,10" Margin="0,0,0,5" BorderBrush="#2A2A4A" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                            <Border Grid.Column="1" Background="#E94560" CornerRadius="4">
                                                <Button Content="Disconnect"
                                                        Command="{Binding DataContext.DisconnectDeviceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        Background="Transparent" Foreground="White" BorderThickness="0"
                                                        Padding="8,4" FontSize="11" Cursor="Hand"/>
</Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border Background="#16213E" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Actions" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
                        <Button Content="📱 Use Phone as Screen" 
                                Command="{Binding UsePhoneAsScreenCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="40"
                                Margin="0,0,0,10"/>
                        <Button Content="🔄 Reorder Displays" 
                                Command="{Binding ReorderCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="40"
                                Margin="0,0,0,10"/>
                        <Border Background="#E94560" CornerRadius="8" Margin="0">
                                <Button Content="⏏ Disconnect All" 
                                        Command="{Binding DisconnectAllCommand}"
                                        Background="Transparent"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Height="40"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"/>
</Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>